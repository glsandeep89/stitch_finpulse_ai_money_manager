# Copy to .env — never commit .env

# Supabase (Dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: only if you add custom JWT verification elsewhere (API uses auth.getUser)
# SUPABASE_JWT_SECRET=

# DB schema for app tables (must match migration; expose in Supabase API settings)
SUPABASE_DB_SCHEMA=finpulse

# Direct Postgres (optional; migrations via psql/CLI)
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# SimpleFIN Bridge (optional override for the signup URL shown in the app)
# SIMPLEFIN_BRIDGE_SIGNUP_URL=https://bridge.simplefin.org/simplefin/create

# Gemini (Google AI Studio key). Model id if your default is unavailable:
# GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: extra header check for cron/job routes
CRON_SECRET=

# Optional: dev-only API key header (FINPULSE_API_KEY)
FINPULSE_API_KEY=
RENDER_API_KEY=
ENABLE_REWARDS_CATALOG_FALLBACK=false
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3001
# Optional: Logo.dev publishable key for higher-quality merchant logos (https://www.logo.dev). Without it, favicons load via Google/DuckDuckGo fallbacks.
# VITE_MERCHANT_LOGO_TOKEN=
